generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  role           Role
  countries      UserCountry[]
  creditRequests CreditRequest[]

  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  CreditStatusHistory CreditStatusHistory[]
}

enum Role {
  ADMIN
  REVIEWER
  USER
}

model Country {
  id   String @id @default(uuid())
  code String @unique
  name String

  users          UserCountry[]
  creditRequests CreditRequest[]

  createdAt DateTime @default(now())
}

model UserCountry {
  id String @id @default(uuid())

  userId    String
  countryId String

  user    User    @relation(fields: [userId], references: [id])
  country Country @relation(fields: [countryId], references: [id])

  @@unique([userId, countryId])
}

model CreditRequest {
  id       String  @id @default(uuid())
  amount   Decimal @db.Decimal(14, 2)
  currency String

  applicantName  String
  applicantEmail String

  countryId String
  country   Country @relation(fields: [countryId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  status CreditStatus @default(PENDING)

  evaluations   CreditEvaluation[]
  statusHistory CreditStatusHistory[]

  createdAt DateTime @default(now())
}

enum CreditStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model CreditStatusHistory {
  id String @id @default(uuid())

  creditRequestId String
  creditRequest   CreditRequest @relation(fields: [creditRequestId], references: [id])

  previousStatus CreditStatus?
  newStatus      CreditStatus

  changedById String?
  changedBy   User?   @relation(fields: [changedById], references: [id])

  createdAt DateTime @default(now())
}

model CreditEvaluation {
  id String @id @default(uuid())

  creditRequestId String
  creditRequest   CreditRequest @relation(fields: [creditRequestId], references: [id])

  score     Int
  riskLevel String
  decision  CreditStatus

  evaluatedAt DateTime @default(now())
}